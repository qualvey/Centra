{
  "source": {
    "type": "stdin",
    "unit": "sing-box",
    "history": {
      "enabled": false,
      "since": "",
      "follow": true,
      "resume": false,
      "checkpoint_file": ".eventguard/journalctl.checkpoint"
    }
  },
  "storage": {
    "type": "memory",
    "path": ".eventguard/eventguard.db"
  },
  "rules": {
    "reality_invalid_handshake": {
      "enabled": true,
      "threshold": 5
    }
  }
}
